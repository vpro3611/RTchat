{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "baseUrl": "./src",
    "types": ["node", "jest"],
    "typeRoots": ["./node_modules/@types", "./src/types"],

  },
  "include": ["src", "__tests__"]
}
